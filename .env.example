# ============================================================
# RockerPilates - Exemplo de variaveis de ambiente
# ============================================================
# Este arquivo e apenas um modelo.
# Nao coloque secrets reais aqui.
# Em producao, configure os valores reais diretamente no servidor,
# no painel da hospedagem, no .env de producao fora do Git,
# ou no mecanismo seguro de secrets da infraestrutura.
# ============================================================


# ============================================================
# PostgreSQL
# ============================================================

POSTGRES_DB=usuarios_db
POSTGRES_USER=rocker
POSTGRES_PASSWORD=troque-esta-senha-em-producao

DB_USERNAME=rocker
DB_PASSWORD=troque-esta-senha-em-producao

USUARIOS_DB_URL=jdbc:postgresql://postgres:5432/usuarios_db
GERENCIADOR_DB_URL=jdbc:postgresql://postgres:5432/gerenciador_db


# ============================================================
# JWT - Admin / usuarios-service
# ============================================================

JWT_SECRET=troque-este-secret-admin-em-producao-com-mais-de-32-caracteres
JWT_EXPIRATION=86400000


# ============================================================
# JWT - Aluno / gerenciador-service + BFF
# ============================================================
# O mesmo JWT_ALUNO_SECRET precisa ser usado no gerenciador-service
# e no bff-pilates, porque o gerenciador emite o token do aluno
# e o BFF valida esse token.

JWT_ALUNO_SECRET=troque-este-secret-aluno-em-producao-com-mais-de-32-caracteres
JWT_ALUNO_EXPIRATION=86400000


# ============================================================
# URLs internas entre servicos Docker
# ============================================================

USUARIOS_URL=http://usuarios-service:8081
GERENCIADOR_URL=http://gerenciador-service:8082


# ============================================================
# Token interno BFF -> microservicos
# ============================================================
# Valor local apenas de exemplo.
# Em producao, usar valor forte fora do Git e igual no BFF
# e no gerenciador-service.

INTERNAL_SERVICE_TOKEN=troque-este-token-interno-em-producao


# ============================================================
# Frontend / BFF
# ============================================================

# Em desenvolvimento local no Windows, pode ser necessario usar
# http://127.0.0.1:8080 para chamadas feitas pelo browser.
NEXT_PUBLIC_BFF_URL=http://127.0.0.1:8080
BFF_INTERNAL_URL=http://bff-pilates:8080


# ============================================================
# Cookies / Seguranca
# ============================================================

APP_COOKIE_SECURE=false


# ============================================================
# CORS
# ============================================================

# Desenvolvimento local: permitir localhost e 127.0.0.1.
# Producao: trocar pelo dominio real do frontend. Nunca usar wildcard (*).
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ============================================================
# Spring
# ============================================================

SPRING_PROFILES_ACTIVE=dev


# ============================================================
# Storage local
# ============================================================

UPLOAD_DIR=uploads

# Ativar somente em producao com HTTPS configurado
APP_SECURITY_HSTS_ENABLED=false

